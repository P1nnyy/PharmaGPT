name: PharmaGPT CI/CD

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  lint-and-test:
    runs-on: ubuntu-latest
    services:
      neo4j:
        image: neo4j:5.12-community
        ports:
          - 7687:7687
          - 7474:7474
        env:
          NEO4J_AUTH: neo4j/password
          NEO4J_apoc_export_file_enabled: "true"
          NEO4J_apoc_import_file_enabled: "true"
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install pytest flake8

      - name: Lint with flake8
        run: |
          # stop the build if there are Python syntax errors or undefined names
          flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics
          # exit-zero treats all errors as warnings. The GitHub editor is 127 chars wide
          flake8 . --count --exit-zero --max-complexity=10 --max-line-length=127 --statistics

      - name: Run Backend Tests
        env:
          NEO4J_URI: bolt://localhost:7687
          NEO4J_USER: neo4j
          NEO4J_PASSWORD: password
          GOOGLE_API_KEY: ${{ fromJSON(toJSON(secrets)).GOOGLE_API_KEY }}
          PYTHONPATH: .
        run: |
          pytest tests/test_api.py tests/test_schema.py

  frontend-ci:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ./frontend
    steps:
      - uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '24'
          cache: 'npm'
          cache-dependency-path: './frontend/package-lock.json'

      - name: Install Dependencies
        run: npm install

      - name: Build Frontend
        run: npm run build

  e2e-tests:
    needs: [frontend-ci]
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ./frontend
    steps:
      - uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '24'

      - name: Install Dependencies
        run: npm install

      - name: Install Playwright Browsers
        run: npx playwright install --with-deps chromium

      - name: Run Playwright tests
        run: npx playwright test
        env:
          CI: true

  ai-code-review:
    needs: [lint-and-test, frontend-ci]
    if: github.event_name == 'pull_request'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: AI Code Review
        env:
          GOOGLE_API_KEY: ${{ fromJSON(toJSON(secrets)).GOOGLE_API_KEY }}
          GITHUB_TOKEN: ${{ fromJSON(toJSON(secrets)).GITHUB_TOKEN }}
          PYTHONPATH: .
        run: |
          python scripts/ai_code_review.py

  extraction-evals:
    needs: [lint-and-test]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run Langfuse Evals
        env:
          LANGFUSE_SECRET_KEY: ${{ fromJSON(toJSON(secrets)).LANGFUSE_SECRET_KEY }}
          LANGFUSE_PUBLIC_KEY: ${{ fromJSON(toJSON(secrets)).LANGFUSE_PUBLIC_KEY }}
          LANGFUSE_HOST: "https://cloud.langfuse.com"
          GOOGLE_API_KEY: ${{ fromJSON(toJSON(secrets)).GOOGLE_API_KEY }}
          PYTHONPATH: .
        run: |
          python scripts/run_evals.py

  notify-status:
    needs: [extraction-evals, e2e-tests, ai-code-review]
    if: always()
    runs-on: ubuntu-latest
    steps:
      - name: Send Build Status Notification
        env:
          BUILD_STATUS: ${{ job.status }}
          WEBHOOK_URL: ${{ fromJSON(toJSON(secrets)).NOTIFICATION_WEBHOOK_URL }}
        run: |
          if [ -n "$WEBHOOK_URL" ]; then
            curl -X POST -H 'Content-type: application/json' --data "{\"text\":\"PharmaGPT Build Status: $(echo $BUILD_STATUS)\"}" $WEBHOOK_URL
          else
            echo "Skipping notification: WEBHOOK_URL not set."
          fi
